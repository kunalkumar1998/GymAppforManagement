# supabase/.env.example
# Set these via: supabase secrets set KEY=value
# Or via: Supabase Dashboard → Edge Functions → Secrets

# ── Auto-injected by Supabase (no action needed) ──────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # auto-injected in prod

# ── SMS Provider (choose one) ─────────────────────────────────────────────────
SMS_PROVIDER=msg91    # "msg91" for India (recommended) | "twilio" for international

# ── MSG91 (India — recommended, ~₹0.15/SMS) ──────────────────────────────────
# Sign up at: https://msg91.com
# Get Auth Key from: Dashboard → API → Auth Key
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=IRPULS       # 6-char alphanumeric sender ID (register with MSG91)

# ── Twilio (alternative / international) ─────────────────────────────────────
# Sign up at: https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1415XXXXXXX   # your Twilio phone number

# ── Set secrets via CLI ───────────────────────────────────────────────────────
# supabase secrets set SMS_PROVIDER=msg91
# supabase secrets set MSG91_AUTH_KEY=your_key
# supabase secrets set MSG91_SENDER_ID=IRPULS
